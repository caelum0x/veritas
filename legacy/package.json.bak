{
  "name": "veritas-cap-agent",
  "version": "1.0.0",
  "description": "Veritas — an A2A fact-verification & source-provenance agent on the CROO Agent Protocol (CAP). Other agents hire it to verify claims with cited sources and a tamper-evident, on-chain-auditable provenance record.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "verify:local": "tsx src/cli.ts",
    "requester": "tsx examples/requester.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@croo-network/sdk": "^0.2.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
