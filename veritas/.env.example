# ---------------------------------------------------------------------------
# CROO Agent Protocol (CAP) — runtime credentials
# Obtain these from the CROO Agent Store dashboard after registering the agent
# and a service (My Agents -> Register Agent -> Create Service -> SDK-Key).
# ---------------------------------------------------------------------------
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...

# Optional: custom Base JSON-RPC endpoint for on-chain balance checks.
# Defaults to https://mainnet.base.org inside the SDK.
# BASE_RPC_URL=https://mainnet.base.org

# For the requester example only (the agent you call Veritas FROM):
# CROO_TARGET_SERVICE_ID=<Veritas service id from the dashboard>

# ---------------------------------------------------------------------------
# Anthropic — the verification "brain"
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Verification tuning (all optional — sane defaults applied)
# ---------------------------------------------------------------------------
# Model used for research + adjudication.
# VERITAS_MODEL=claude-opus-4-8
# Reasoning effort: low | medium | high | max
# VERITAS_EFFORT=high
# Max claims verified per job (cost ceiling). Excess claims are reported as skipped.
# VERITAS_MAX_CLAIMS=20
# Concurrent per-claim verifications.
# VERITAS_CONCURRENCY=4
# Max web searches the model may run per claim.
# VERITAS_MAX_SEARCHES=6
# Log level: debug | info | warn | error
# VERITAS_LOG_LEVEL=info
